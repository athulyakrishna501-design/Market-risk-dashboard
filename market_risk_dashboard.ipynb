    "    parametric_var[cl] = var\n",
    "    print(f\"  {cl:.0%} VaR:  {var:.4f}  ({var*100:.2f}%)\")\n",
    "\n",
    "print(f\"\\n  μ = {mu:.6f},  σ = {sigma:.6f}\")\n",
